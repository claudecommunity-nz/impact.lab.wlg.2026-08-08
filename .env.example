# ─────────────────────────────────────────────────────────────────────────────
# WCC Emergency Hack — environment template
#
# cp .env.example .env   then fill in the TWO empty secrets from your check-in
# card. .env is gitignored; NEVER commit secrets — this repo is public.
# The only prefilled values below are public-by-design (reads are public anyway;
# every write additionally requires a module token, which is NOT in this file).
# ─────────────────────────────────────────────────────────────────────────────

# Shared Supabase project URL (public).
SUPABASE_URL=https://wjxnahicdudybycedgih.supabase.co

# Supabase publishable key (public-by-design; read-only in practice — all writes
# are gated by per-module credentials via RLS).
SUPABASE_PUBLISHABLE_KEY=sb_publishable_BCJWxdlEi5ZffB6tii63vA_Do4n-Ox-

# This team's loader-only write token — from its check-in card. wcc_impact
# attaches it as x-module-token; RLS permits only this module's rows, table
# namespace, and media prefix. Never commit it or give it a NEXT_PUBLIC_ name.
MODULE_TOKEN=

# Migration-only shared room token. Participants leave this empty. Organisers
# may open a short legacy window while replacing old cards; it is off by default.
EVENT_TOKEN=

# Your team's spend-capped Anthropic API key — from your check-in card.
# Used by wcc_impact's ask_claude() / analyze_image(). Revoked after the event.
ANTHROPIC_API_KEY=

# Durable signal publishing is on by default: validated signals are persisted
# locally before the network write and replayed after venue-WiFi outages.
# Set to 0 only when deliberately testing immediate failure behaviour.
WCC_IMPACT_DURABLE_SIGNALS=1

# ── Organiser deployment only: Lab activity ─────────────────────────────────
# Participants leave these blank. GITHUB_REPOSITORY may be changed for a fork.
# GITHUB_TOKEN is optional, server-only, and should be a fine-grained read-only
# token for repository contents, pull requests, and checks. Without it, the Lab
# activity page still shows public commits and PRs but marks check status
# unavailable. NEVER prefix this token with NEXT_PUBLIC_.
GITHUB_REPOSITORY=claudecommunity-nz/impact.lab.wlg.2026-08-08
GITHUB_TOKEN=

# ── NEXT_PUBLIC_ mirrors for the dashboard ──────────────────────────────────
# Next.js only exposes NEXT_PUBLIC_-prefixed vars to browser code, so the
# dashboard reads these mirrors of the values above.

NEXT_PUBLIC_SUPABASE_URL=https://wjxnahicdudybycedgih.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_BCJWxdlEi5ZffB6tii63vA_Do4n-Ox-

# No NEXT_PUBLIC module credential exists. Browser writes use Supabase Auth and
# an organiser-assigned app_metadata.module_id claim; anonymous users are read-only.
