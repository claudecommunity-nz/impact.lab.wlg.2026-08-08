{
  "name": "@wcc-impact/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Design tokens (Tailwind v4 @theme CSS + severity colour map) and small core-internal components for the WCC emergency hack. @wcc-impact/plugin-sdk re-exports the public parts; module UIs never import @wcc-impact/ui directly.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tokens.css": "./src/tokens.css",
    "./lib/*": "./src/lib/*.ts",
    "./components/*": "./src/components/*.tsx"
  },
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@wcc-impact/shared": "workspace:*",
    "@hookform/resolvers": "^5.4.0",
    "@shadcn/react": "^0.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.25.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.4",
    "react-day-picker": "^10.0.1",
    "react-hook-form": "^7.82.0",
    "react-resizable-panels": "^4.12.2",
    "recharts": "3.10.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
}
